# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL (leave empty to use long-polling in development)
TELEGRAM_WEBHOOK_URL=

# =============================================================================
# Anthropic (Claude)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper model for classification & extraction (Haiku is ~10x cheaper)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# =============================================================================
# PostgreSQL (optional — leave empty to use JSON/in-memory fallback)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_support_bot

# =============================================================================
# Google (Gemini Embeddings)
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSIONS=3072

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Zendesk Help Center
# =============================================================================
ZENDESK_SUBDOMAIN=support.datatruck.io
# Optional: only needed if your Help Center requires authentication
ZENDESK_API_TOKEN=
ZENDESK_EMAIL=

# =============================================================================
# External Support Ticket API
# =============================================================================
SUPPORT_API_BASE_URL=https://your-support-api.example.com
SUPPORT_API_KEY=your_support_api_key_here

# poll | webhook
TICKET_CALLBACK_MODE=poll
TICKET_POLL_INTERVAL_SECONDS=60

# =============================================================================
# Agent Behaviour
# =============================================================================
# Minimum Qdrant similarity score to accept a retrieved chunk (0.0 - 1.0)
SUPPORT_MIN_CONFIDENCE_SCORE=0.75

# Number of recent messages to keep per group for context
GROUP_CONTEXT_WINDOW=20

# How many top chunks to retrieve from Qdrant
RAG_TOP_K=5

# Hours between automatic Zendesk sync runs (0 = disabled)
ZENDESK_SYNC_INTERVAL_HOURS=6

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
