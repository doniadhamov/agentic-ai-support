# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL (leave empty to use long-polling in development)
TELEGRAM_WEBHOOK_URL=

# =============================================================================
# Anthropic (Claude)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper model for classification, extraction & thread routing (Haiku is ~10x cheaper)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# =============================================================================
# PostgreSQL (required for conversation thread & Zendesk ticket sync)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_support_bot

# =============================================================================
# Google (Gemini Embeddings)
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSIONS=3072

# Gemini Flash model for voice message transcription
GEMINI_FLASH_MODEL=gemini-2.0-flash

# Max voice message duration to transcribe (seconds)
MAX_VOICE_DURATION_SECONDS=120

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Zendesk (required — Help Center articles + Support Tickets API)
# =============================================================================
ZENDESK_HELP_CENTER_SUBDOMAIN=support.datatruck.io
ZENDESK_API_SUBDOMAIN=
ZENDESK_EMAIL=your_zendesk_email_here
ZENDESK_API_TOKEN=your_zendesk_api_token_here

# Zendesk user ID of the bot — auto-resolved at startup if not set (env → DB → create via Profiles API).
# Set manually to skip the auto-resolution. Used as author_id for bot comments.
ZENDESK_BOT_USER_ID=0

# Zendesk user ID of the API token owner (admin account) — REQUIRED for webhook filtering.
# All API-originated comments have this user as actor_id. The webhook handler uses it
# to skip echoed comments (user messages synced from Telegram, bot replies).
ZENDESK_ADMIN_USER_ID=0

# Zendesk custom field ID for storing Telegram chat ID on tickets
# Create a custom field in Zendesk Admin → Ticket Fields → Add field (Text)
ZENDESK_TELEGRAM_CHAT_ID_FIELD_ID=

# =============================================================================
# Agent Behaviour
# =============================================================================
# Minimum Qdrant similarity score to accept a retrieved chunk (0.0 - 1.0)
SUPPORT_MIN_CONFIDENCE_SCORE=0.70

# Number of recent messages to keep per group for context
GROUP_CONTEXT_WINDOW=50

# How many top chunks to retrieve from Qdrant
RAG_TOP_K=5

# Min RAG score to override NON_SUPPORT → SUPPORT_QUESTION (0.0 - 1.0)
RAG_OVERRIDE_MIN_SCORE=0.75

# Hours between automatic Zendesk article sync runs (0 = disabled)
ZENDESK_SYNC_INTERVAL_HOURS=24

# =============================================================================
# Admin Dashboard
# =============================================================================
ADMIN_PASSWORD=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
